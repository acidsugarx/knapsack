{
  "name": "knapsack-pi",
  "version": "0.1.0",
  "description": "Token reduction & persistent memory for Pi coding agent — compress tool outputs, save decisions across sessions, survive compaction, backed by Obsidian",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "src/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "pi": {
    "extensions": ["./src/index.ts"],
    "skills": ["./skills"]
  },
  "scripts": {
    "check": "biome check .",
    "fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "prepublishOnly": "npm run check && npm run test && npm run typecheck"
  },
  "keywords": [
    "pi",
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "token-reduction",
    "context-compression",
    "persistent-memory",
    "agent-memory",
    "obsidian",
    "tool-output-compression",
    "ccr",
    "compress-cache-retrieve"
  ],
  "author": "acidsugarx",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/acidsugarx/knapsack.git"
  },
  "bugs": {
    "url": "https://github.com/acidsugarx/knapsack/issues"
  },
  "homepage": "https://github.com/acidsugarx/knapsack#readme",
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.70.0"
  },
  "dependencies": {
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-ai": "*",
    "typebox": "*",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
